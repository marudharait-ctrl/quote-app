<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Quote System' %> — Marudhara Group</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<% if (typeof user !== 'undefined' && user && user.userId) { %>
<nav class="navbar">
  <div class="nav-brand">
    <a href="/quotes" class="brand-link">
      <img src="/logo.png" alt="Marudhara Group" class="nav-logo">
      <div class="brand-text">
        <span class="brand-name">Marudhara Group</span>
        <span class="brand-sub">Quote System</span>
      </div>
    </a>
  </div>
  <div class="nav-links">
    <a href="/quotes" class="<%= typeof activePage !== 'undefined' && activePage === 'quotes' ? 'active' : '' %>">📋 Quotes</a>
    <a href="/quotes/new" class="<%= typeof activePage !== 'undefined' && activePage === 'new' ? 'active' : '' %>">➕ New Quote</a>
    <a href="/admin/pricing/master" class="<%= typeof activePage !== 'undefined' && activePage === 'master' ? 'active' : '' %>">📊 Rate Sheet</a>
    <% if (user.userRole === 'admin') { %>
    <a href="/admin" class="<%= typeof activePage !== 'undefined' && activePage === 'admin' ? 'active' : '' %>">⚙️ Admin</a>
    <a href="/admin/audit" class="<%= typeof activePage !== 'undefined' && activePage === 'audit' ? 'active' : '' %>">📜 Audit</a>
    <a href="/admin/pricing" class="<%= typeof activePage !== 'undefined' && activePage === 'pricing' ? 'active' : '' %>">💰 Pricing Config</a>
    <% } %>
  </div>
  <div class="nav-user">
    <span class="avatar"><%= user.fullName.charAt(0).toUpperCase() %></span>
    <span class="nav-username"><%= user.fullName %></span>
    <% if (user.userRole === 'admin') { %><span class="badge-admin">Admin</span><% } %>
    <a href="/logout" class="btn-logout">Logout</a>
  </div>
</nav>
<% } else { %>
<!-- Login/Register page header -->
<div class="auth-topbar">
  <img src="/logo.png" alt="Marudhara Group" class="auth-topbar-logo">
</div>
<% } %>
<main class="main-content">
