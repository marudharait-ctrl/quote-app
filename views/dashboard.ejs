<% var title='Dashboard'; var activePage='dashboard'; %>
<%- include('layout') %>
<div class="page-header">
  <div>
    <h1>Dashboard</h1>
    <p>Choose the tool you want to work in.</p>
  </div>
</div>

<div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:20px; margin-top:24px;">
  <div class="card">
    <div class="card-header"><h3>📋 Quote App</h3></div>
    <div class="card-body">
      <p>Create, manage, and review woven bag quotes without changing existing quote logic.</p>
      <a href="/quotes" class="btn btn-primary">Open Quote App</a>
    </div>
  </div>
  <div class="card">
    <div class="card-header"><h3>📦 Laminate App</h3></div>
    <div class="card-body">
      <p>Open the laminate pricing calculator with database-backed defaults and saved material settings.</p>
      <a href="/laminate" class="btn btn-secondary">Open Laminate App</a>
    </div>
  </div>
</div>
<%- include('layout_footer') %>
